{
	"name": "tau",
	"private": true,
	"type": "module",
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"dependencies": {
		"@effect/platform-node": "4.0.0-beta.54",
		"effect": "4.0.0-beta.54",
		"nanoid": "^5.1.7",
		"node-pty": "^1.1.0",
		"yaml": "^2.7.0"
	},
	"devDependencies": {
		"@effect/language-service": "latest",
		"@effect/vitest": "4.0.0-beta.54",
		"@mariozechner/pi-agent-core": "^0.62.0",
		"@mariozechner/pi-ai": "^0.62.0",
		"@mariozechner/pi-coding-agent": "^0.62.0",
		"@mariozechner/pi-tui": "^0.62.0",
		"@sinclair/typebox": "^0.34.47",
		"@types/node": "latest",
		"knip": "latest",
		"oxfmt": "latest",
		"oxlint": "latest",
		"typescript": "latest",
		"vitest": "latest"
	},
	"scripts": {
		"test": "vitest --run --passWithNoTests",
		"typecheck": "tsc --noEmit",
		"lint": "npx oxlint src && node ./scripts/check-runfork-usage.mjs",
		"format": "npx oxfmt src test",
		"format:check": "npx oxfmt --check src test",
		"knip": "npx knip",
		"effect:diagnostics": "npx effect-language-service diagnostics --project tsconfig.json --format pretty --progress",
		"gate": "npm run typecheck && npm run lint && npm run test"
	}
}
